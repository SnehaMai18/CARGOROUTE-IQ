package com.example.demo.repository;

import com.example.demo.entities.ProofOfDelivery;
import com.example.demo.entities.enums.PodType;
import com.example.demo.entities.enums.ProofOfDeliveryStatus;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.data.jpa.test.autoconfigure.DataJpaTest;
import org.springframework.boot.jpa.test.autoconfigure.TestEntityManager;
import org.springframework.test.context.TestPropertySource;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;

@DataJpaTest
@TestPropertySource(properties = {
        "spring.datasource.url=jdbc:h2:mem:testdb",
        "spring.jpa.hibernate.ddl-auto=create-drop",
        "eureka.client.enabled=false"
})
class ProofOfDeliveryRepositoryTest {

    @Autowired
    private TestEntityManager entityManager;

    @Autowired
    private ProofOfDeliveryRepository proofOfDeliveryRepository;

    private ProofOfDelivery pod1;
    private ProofOfDelivery pod2;
    private ProofOfDelivery pod3;

    @BeforeEach
    void setUp() {
        // Clear previous data if necessary
        entityManager.getEntityManager().createQuery("DELETE FROM ProofOfDelivery").executeUpdate();

        pod1 = buildPod(1001L, 500L, PodType.Photo, ProofOfDeliveryStatus.PENDING);
        pod2 = buildPod(1002L, 501L, PodType.Signature, ProofOfDeliveryStatus.UPLOADED);
        pod3 = buildPod(1003L, 500L, PodType.Photo, ProofOfDeliveryStatus.VERIFIED);

        entityManager.persist(pod1);
        entityManager.persist(pod2);
        entityManager.persist(pod3);
        entityManager.flush();
    }

    private ProofOfDelivery buildPod(Long bookingId, Long driverId, PodType podType, ProofOfDeliveryStatus status) {
        ProofOfDelivery pod = new ProofOfDelivery();
        pod.setBookingID(bookingId);
        // Ensure your Entity has a setDriverId method matching findByDriverId in repository
        pod.setDriverId(driverId); 
        pod.setDeliveredAt(LocalDateTime.now());
        pod.setReceivedBy("Customer");
        pod.setPodURI("http://pod/" + bookingId);
        pod.setPodType(podType);
        pod.setStatus(status);
        return pod;
    }

    @Test
    @DisplayName("findByDriverId — returns matching PODs for a specific driver")
    void testFindByDriverId() {
        List<ProofOfDelivery> driverPods = proofOfDeliveryRepository.findByDriverId(500L);

        assertThat(driverPods).hasSize(2);
        assertThat(driverPods).extracting(ProofOfDelivery::getDriverId).containsOnly(500L);
    }

    @Test
    @DisplayName("findByBookingID — returns matching POD")
    void testFindByBookingID() {
        ProofOfDelivery found = proofOfDeliveryRepository.findByBookingID(1002L);

        assertThat(found).isNotNull();
        assertThat(found.getBookingID()).isEqualTo(1002L);
    }

    @Test
    @DisplayName("Delete POD by ID — record no longer exists")
    void testDeleteById() {
        Long id = pod1.getPodID();
        proofOfDeliveryRepository.deleteById(id);
        
        // Use repository to verify instead of just manager
        assertThat(proofOfDeliveryRepository.findById(id)).isNotPresent();
    }

    @Test
    @DisplayName("Find all PODs — returns all records")
    void testFindAll() {
        List<ProofOfDelivery> all = proofOfDeliveryRepository.findAll();
        assertThat(all).hasSize(3);
    }
}